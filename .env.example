# Copie para .env na raiz do projeto:  cp .env.example .env
#
# Este arquivo concentra:
# - docker compose (POSTGRES_* e POSTGRES_PORT)
# - Prisma no server/ (DATABASE_URL) — os scripts npm em server/ leem ../.env

POSTGRES_USER=jlturismo
POSTGRES_PASSWORD=troque_esta_senha
POSTGRES_DB=jlturismo
# Porta no host; mude se já houver outro Postgres na 5432
POSTGRES_PORT=5432

# Mesmo usuário/senha/db acima. Host localhost = seu Mac; dentro do Compose use host "postgres".
DATABASE_URL=postgresql://jlturismo:troque_esta_senha@localhost:5432/jlturismo
