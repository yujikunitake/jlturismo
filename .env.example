# Copie para .env e ajuste.
# docker compose lê estas variáveis automaticamente.

POSTGRES_USER=jlturismo
POSTGRES_PASSWORD=troque_esta_senha
POSTGRES_DB=jlturismo
# Porta padrão; mude se já tiver outro Postgres na 5432
POSTGRES_PORT=5432

# String de conexão para o backend/API (quando existir):
# host = localhost ao rodar o app fora do Docker; host = postgres dentro da rede do compose
DATABASE_URL=postgresql://jlturismo:troque_esta_senha@localhost:5432/jlturismo
